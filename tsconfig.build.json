{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/runtime/**/*.ts",
    "src/runtime/**/*.tsx",
    "src/vite/**/*.ts",
    "src/cli/**/*.ts",
    "src/server/**/*.ts",
    "src/internal/**/*.ts",
    "src/internal/**/*.tsx",
    "src/analytics.ts",
    "src/cookie.ts",
    "src/session.ts",
    "src/seo.ts",
    "src/debug/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
