{
  "compilerOptions": {
    "paths": {
      "~/*": ["./src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "server.ts",
    "scripts/**/*.ts",
    "vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}